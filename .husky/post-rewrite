#!/usr/bin/env sh
# roborev post-rewrite hook v2 - remaps reviews after rebase/amend
_roborev_remap() {
ROBOREV="/usr/local/Cellar/roborev/0.52.0/bin/roborev"
if [ ! -x "$ROBOREV" ]; then
    ROBOREV=$(command -v roborev 2>/dev/null)
    [ -z "$ROBOREV" ] || [ ! -x "$ROBOREV" ] && return 0
fi
"$ROBOREV" remap --quiet 2>/dev/null
}
_roborev_remap
